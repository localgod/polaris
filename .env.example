# Neo4j Database Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=devpassword
NEO4J_DATABASE=neo4j

# Test Database Configuration (optional)
# Tests use namespace-based isolation (TEST_ prefix) for data separation
# NEO4J_TEST_URI=bolt://localhost:7687
# NEO4J_TEST_USERNAME=neo4j
# NEO4J_TEST_PASSWORD=devpassword
# NEO4J_TEST_DATABASE=test

# Authentication Configuration
# Generate a secure secret: openssl rand -base64 32
AUTH_SECRET=replace-me-in-production-use-openssl-rand-base64-32

# GitHub OAuth (create app at https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Auth Origin (optional - auto-detected for Gitpod)
# For local development: http://localhost:3000/api/auth (default)
# For Gitpod: Set to the environment's preview URL + /api/auth
# For production: Set to your domain
# AUTH_ORIGIN=https://your-domain.com/api/auth

# Required when running behind a reverse proxy (Gitpod, Cloudflare, nginx, etc.)
# Tells next-auth to trust the Host header for constructing redirect_uri
AUTH_TRUST_HOST=true

# Superuser Configuration
# Comma-separated list of email addresses that should have superuser access
# Superusers can manage users, assign teams, and have full write access
SUPERUSER_EMAILS=admin@company.com,lead@company.com

SEED_API_TOKEN=
