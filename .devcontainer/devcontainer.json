// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
	"name": "Polaris Local Dev Container",
	// Use docker-compose to start both app and neo4j services
	"dockerComposeFile": "docker-compose-local.yml",
	"service": "app",
	"workspaceFolder": "/workspaces/polaris",
	"features": {
		"ghcr.io/wxw-matt/devcontainer-features/command_runner:0": {},
		"ghcr.io/postfinance/devcontainer-features/docker-out:1": {},
		"ghcr.io/srzstephen/devcontainer-features/act:1": {},
		"ghcr.io/devcontainers/features/github-cli:1": {}
	},

	// Use 'postCreateCommand' to run commands after the container is created.
	"postCreateCommand": "bash /workspaces/polaris/.devcontainer/scripts/post-create.sh",

	// Run as node user to avoid permission issues
	"remoteUser": "node",
	
	// Allow node user to use sudo without password
	"updateContentCommand": "sudo chown -R node:node /workspaces/polaris/node_modules || true",

	// Ensure node_modules has proper permissions
	"containerEnv": {
		"npm_config_cache": "/tmp/.npm"
	},

	// Forward the dev server port so the host browser can reach it reliably.
	// On Linux host-network setups, prefer http://127.0.0.1:3000 if localhost
	// resolves inconsistently in the browser.
	"forwardPorts": [
		3000
	],
	"portsAttributes": {
		"3000": {
			"label": "Nuxt dev server",
			"protocol": "http",
			"requireLocalPort": true
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"Anthropic.claude-code",
				"Vue.volar"
			]
		}
	}
}
