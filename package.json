{
  "name": "polaris",
  "version": "0.5.7",
  "description": "Enterprise technology catalog built with Nuxt 4 and Neo4j graph database",
  "type": "module",
  "private": true,
  "author": "Johannes Skov Frandsen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/localgod/polaris.git"
  },
  "bugs": {
    "url": "https://github.com/localgod/polaris/issues"
  },
  "homepage": "https://github.com/localgod/polaris#readme",
  "keywords": [
    "nuxt",
    "neo4j",
    "graph-database",
    "technology-catalog",
    "enterprise",
    "sbom",
    "dependency-management",
    "typescript",
    "vue"
  ],
  "scripts": {
    "build": "npm run docs:api && nuxt build",
    "dev": "nuxt dev --host",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "npx eslint",
    "lint:fix": "npx eslint  --fix",
    "mdlint": "markdownlint '**/*.md' --ignore node_modules",
    "migrate": "tsx schema/scripts/migrate.ts",
    "migrate:status": "tsx schema/scripts/migrate.ts status",
    "migrate:up": "tsx schema/scripts/migrate.ts up",
    "migrate:down": "tsx schema/scripts/migrate.ts down",
    "migrate:create": "tsx schema/scripts/migrate.ts create",
    "migrate:validate": "tsx schema/scripts/migrate.ts validate",
    "schema:query": "node scripts/query-schema.js",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:server": "vitest run test/server",
    "test:server:api": "vitest run test/server/api",
    "test:server:services": "vitest run test/server/services",
    "test:server:repositories": "vitest run test/server/repositories",
    "test:server:utils": "vitest run test/server/utils",
    "test:app": "vitest run test/app",
    "test:app:e2e": "vitest run test/app/e2e",
    "test:schema": "vitest run test/schema",
    "test:unit": "vitest run test/server/services test/server/repositories test/server/utils test/app/components test/app/composables",
    "test:smoke": "vitest run -t '@smoke'",
    "test:coverage": "vitest run --coverage",
    "test:coverage:check": "vitest run --config vitest.coverage.config.ts --coverage",
    "test:ci": "vitest run --reporter=verbose --reporter=json --outputFile=test-results.json",
    "test:vitest-ui": "vitest --ui",
    "seed": "tsx schema/scripts/seed.ts",
    "seed:clear": "tsx schema/scripts/seed.ts --clear",
    "seed:github": "tsx schema/scripts/seed-github.ts",
    "schema:dump": "tsx schema/scripts/dump-schema.ts",
    "docs:api": "tsx server/scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@cyclonedx/cdxgen": "^12.4.1",
    "@nuxt/eslint": "^1.13.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxt/ui": "4.7.1",
    "@sidebase/nuxt-auth": "1.2.0",
    "ajv": "^8.20.0",
    "d3": "^7.9.0",
    "eslint": "^10.4.0",
    "mermaid": "^11.15.0",
    "next-auth": "4.22.5",
    "nuxt": "4.4.6",
    "nuxt-neo4j": "^0.0.4",
    "pino": "^10.3.1",
    "semver": "^7.8.0",
    "spdx-expression-parse": "^4.0.0",
    "spdx-license-list": "^6.11.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "vue": "^3.5.33",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@amiceli/vitest-cucumber": "^6.5.0",
    "@cucumber/cucumber": "^12.9.0",
    "@cucumber/gherkin": "^39.1.0",
    "@cucumber/messages": "^32.3.1",
    "@iconify-json/lucide": "^1.2.108",
    "@playwright/test": "^1.60.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.9.0",
    "@types/semver": "^7.7.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "markdownlint-cli": "^0.48.0",
    "patch-package": "^8.0.1",
    "swagger-jsdoc": "^6.2.8",
    "vitest": "^4.1.6"
  }
}
